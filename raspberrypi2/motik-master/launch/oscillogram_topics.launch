<?xml version="1.0"?>
<!--
  Запуск только топика осциллограммы: /oscillogram_display (Float32), вывод на OLED (I2C 0x3D).
  По умолчанию уровень из /audio/level. Если задать oscillogram_frequency_hz — осциллограмма
  реагирует на уровень в полосе вокруг этой частоты (источник /audio/raw, нужен numpy).

  Команды:
    roslaunch motik oscillogram_topics.launch
    roslaunch motik oscillogram_topics.launch oscillogram_frequency_hz:=440
    roslaunch motik oscillogram_topics.launch oscillogram_frequency_hz:=1000 audio_sample_rate:=44100
-->
<launch>
  <arg name="oscillogram_frequency_hz" default="0" doc="0 = уровень из /audio/level; >0 = уровень по частоте из /audio/raw (Гц)"/>
  <arg name="oscillogram_frequency_band_hz" default="50" doc="Полуширина полосы частот (Гц)"/>
  <arg name="audio_sample_rate" default="16000" doc="Частота дискретизации при использовании oscillogram_frequency_hz"/>
  <arg name="audio_raw_topic" default="/audio/raw" doc="Топик сырого PCM при oscillogram_frequency_hz > 0"/>

  <node name="motik_node" pkg="motik" type="motik_node.py" output="screen">
    <param name="oscillogram_display" value="true"/>
    <param name="oscillogram_frequency_hz" value="$(arg oscillogram_frequency_hz)"/>
    <param name="oscillogram_frequency_band_hz" value="$(arg oscillogram_frequency_band_hz)"/>
    <param name="audio_sample_rate" value="$(arg audio_sample_rate)"/>
    <param name="audio_raw_topic" value="$(arg audio_raw_topic)"/>
  </node>
</launch>
