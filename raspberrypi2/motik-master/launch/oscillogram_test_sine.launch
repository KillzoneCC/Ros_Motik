<?xml version="1.0"?>
<!--
  Проверка анимации осциллограммы на OLED (motik): синусоидальный сигнал в /audio/level.
  Запуск: roslaunch motik oscillogram_test_sine.launch

  Параметры синуса (пакет sound):
    sine_rate  — частота публикации (Гц), по умолчанию 60.
    sine_freq  — частота синусоиды (Гц), по умолчанию 2.0.
-->
<launch>
  <arg name="sine_rate" default="60" doc="Частота публикации уровня (Гц)"/>
  <arg name="sine_freq" default="2.0" doc="Частота синусоиды (Гц)"/>

  <node name="audio_level_test_sine" pkg="sound" type="audio_level_test_sine.py" output="screen">
    <param name="rate" value="$(arg sine_rate)"/>
    <param name="freq" value="$(arg sine_freq)"/>
  </node>

  <include file="$(find motik)/launch/oscillogram_topics.launch">
    <arg name="oscillogram_frequency_hz" value="0"/>
  </include>
</launch>
