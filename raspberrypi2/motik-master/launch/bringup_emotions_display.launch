<?xml version="1.0"?>
<!--
  Полный bringup как ainex_bringup/bringup.launch, но дисплей отключён в ainex_bringup
  (base с oled_mouth:=false) и вывод эмоций на OLED идёт из motik (топик /emotions).
  Использование: roslaunch motik bringup_emotions_display.launch
  На системе без systemd: oled_display.service не запускается — ничего останавливать не нужно.
-->
<launch>
    <arg name="camera_name"     default="camera"/>
    <arg name="image_topic"     default="image_raw"/>
    <arg name="default_emotion" default="neutral"/>

    <include file="$(find ainex_peripherals)/launch/usb_cam_with_calib.launch">
        <arg name="camera_name" value="$(arg camera_name)"/>
        <arg name="image_topic" value="$(arg image_topic)"/>
    </include>

    <!-- base без oled_mouth — дисплей не используется ainex_bringup -->
    <include file="$(find ainex_bringup)/launch/base.launch">
        <arg name="oled_mouth" value="false"/>
    </include>

    <include file="$(find ainex_peripherals)/launch/joystick_control.launch"/>

    <node name="web_video_server" pkg="web_video_server" respawn="true" respawn_delay="2" type="web_video_server" output="screen"/>

    <include file="$(find ainex_app)/launch/rosbridge.launch"/>

    <include file="$(find ainex_app)/launch/start.launch"/>

    <include file="$(find teleop_fetch)/launch/teleop_fetch.launch"/>

    <include file="$(find proverka_nod)/launch/topici_list.launch"/>

    <!-- Вывод эмоций на OLED из топика /emotions (motik_node) -->
    <node name="motik_node" pkg="motik" type="motik_node.py" output="screen">
        <param name="default_emotion" value="$(arg default_emotion)"/>
        <param name="oscillogram_display" value="false"/>
    </node>
</launch>
