<?xml version="1.0"?>
<!--
  Запуск анимации рта на дисплее для проверки: рот плавно открывается и закрывается по синусоиде
  без микрофона и цепочки нод. Нода рта — из ainex_bringup; тестовый публикатор уровня — из test.

  Запуск:
    roslaunch test mouth_animation_test.launch

  Только дисплей и нода рта (статичный рот, без движения):
    roslaunch test mouth_animation_test.launch demo_level:=false

  С выводом звука на карту:
    roslaunch test mouth_animation_test.launch output_device:=plughw:2,0
-->
<launch>
  <arg name="output_device" default="default" doc="ALSA-устройство для воспроизведения (aplay -l). Например plughw:2,0"/>
  <arg name="mouth_sync_hz" default="30" doc="Частота (Гц) обновления рта"/>
  <arg name="demo_level" default="true" doc="Запустить тестовый публикатор уровня — рот двигается по синусоиде"/>
  <param name="/mouth_sync_hz" value="$(arg mouth_sync_hz)"/>
  <!-- Тестовый публикатор: шлёт уровень в /audio/mouth_open_level, рот на дисплее открывается/закрывается -->
  <node if="$(arg demo_level)" name="mouth_level_test_publisher_node" pkg="test" type="mouth_level_test_publisher_node.py" output="screen">
    <param name="rate" value="$(arg mouth_sync_hz)"/>
  </node>
  <!-- Нода анимации рта и дисплея (ainex_bringup) -->
  <include file="$(find ainex_bringup)/launch/oled_mouth.launch">
    <arg name="output_device" value="$(arg output_device)"/>
    <arg name="mouth_sync_hz" value="$(arg mouth_sync_hz)"/>
  </include>
</launch>
