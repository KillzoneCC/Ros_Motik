<?xml version="1.0"?>
<!-- update_rate должен совпадать с частотой рта (/mouth_sync_hz, обычно 30 Гц), чтобы анимация рта шла плавно. -->
<launch>
  <arg name="mouth_sync_hz" default="30" doc="Частота публикации уровня для рта (должна совпадать с третьей нодой и нодой рта)"/>
  <node name="oscillogram_plot_node" pkg="test" type="oscillogram_plot_node.py" output="screen">
    <param name="buffer_size" value="300"/>
    <param name="plot_width" value="400"/>
    <param name="plot_height" value="150"/>
    <param name="update_rate" value="$(arg mouth_sync_hz)"/>
    <param name="output_file" value="/tmp/oscillogram_plot.png"/>
    <param name="mouth_scale" value="3.5"/>
  </node>
</launch>
