<?xml version="1.0"?>
<!-- Частота публикации (rate) должна совпадать с частотой обновления ноды рта: задаётся /mouth_sync_hz или param rate -->
<launch>
  <param name="/mouth_sync_hz" value="30"/>
  <node name="mouth_oscillogram_sync_node" pkg="test" type="mouth_oscillogram_sync_node.py" output="screen">
    <param name="smooth" value="0.75"/>
    <param name="scale" value="2.0"/>
    <param name="min_level" value="0.008"/>
    <param name="rate" value="30.0"/>
  </node>
</launch>
